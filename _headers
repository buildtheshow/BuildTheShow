# Cloudflare Pages — cache headers
# Static assets: cache for 1 year (they have content-hashed names or rarely change)
/ASSETS/styles/*
  Cache-Control: public, max-age=31536000, immutable

/ASSETS/scripts/*
  Cache-Control: public, max-age=31536000, immutable

/ASSETS/Images/*
  Cache-Control: public, max-age=31536000, immutable

/SHARED/Components/*
  Cache-Control: public, max-age=86400

# HTML pages: always revalidate so updates deploy instantly
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/SYSTEM/*
  Cache-Control: public, max-age=0, must-revalidate

/PUBLIC/*
  Cache-Control: public, max-age=0, must-revalidate
