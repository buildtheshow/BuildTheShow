  function rpfRenderProductionFeeSection(template) {
    const s = _regSettings?.payment_settings || {};
    const age = rpfCalcAge(_prefill?.date_of_birth);
    const currSym = { CAD: '$', USD: '$', GBP: '£' }[s.currency || 'CAD'] || '$';
    const currCode = s.currency && s.currency !== 'CAD' ? ` ${s.currency}` : '';
    const fmtAmt = v => {
      if (!v) return null;
      const n = parseFloat(v);
      if (!Number.isFinite(n)) return null;
      const amount = Number.isInteger(n) ? String(n) : n.toFixed(2);
      return `${currSym}${amount}${currCode}`;
    };
    const fmtDate = d => d ? new Date(d + 'T00:00:00').toLocaleDateString('en-CA', { month: 'long', day: 'numeric', year: 'numeric' }) : null;
    const row = (label, value, note = '') => `<div class="rpf-pf-row">
      <span class="rpf-pf-row-label">${esc(label)}</span>
      <span class="rpf-pf-row-value">${esc(value)}${note ? `<span class="rpf-pf-sub-note">${esc(note)}</span>` : ''}</span>
    </div>`;
    const discountFact = (label, value) => value ? `<div class="rpf-pf-discount-fact"><span>${esc(label)}</span><span>${esc(value)}</span></div>` : '';
    const discountCard = ({ name, fieldName, title, description, facts = '', extra = '' }) => `<div class="rpf-pf-discount-card">
      <label class="rpf-pf-discount-check">
        <input type="checkbox" name="${esc(name)}" data-field-name="${esc(fieldName || title)}" />
        <span>
          <span class="rpf-pf-discount-title">${esc(title)}</span>
          <span class="rpf-pf-discount-desc">${esc(description)}</span>
        </span>
      </label>
      ${facts ? `<div class="rpf-pf-discount-facts">${facts}</div>` : ''}
      ${extra ? `<div class="rpf-pf-discount-extra">${extra}</div>` : ''}
    </div>`;

    const mode = s.mode || 'none';
    let feeRows = '';
    let feeTotal = '';
    if (mode === 'none' || !mode) {
      feeRows = `<div class="rpf-pf-none">No production fee has been configured for this show.</div>`;
    } else if (mode === 'flat') {
      feeRows = [
        s.fee ? row('Registration fee', fmtAmt(s.fee)) : null,
        s.fee_due_date ? row('Due date', fmtDate(s.fee_due_date)) : null,
        s.late_fee_date ? row('Late payment after', fmtDate(s.late_fee_date)) : null,
      ].filter(Boolean).join('') || `<div class="rpf-pf-none">Fee amount not yet configured.</div>`;
    } else if (mode === 'split') {
      const insts = (s.split_installments || []).filter((_, i) => i < (s.split_count || 2));
      if (insts.length) {
        feeRows = insts.map((inst, i) => {
          const dateLabel = inst.due_date ? ` <em style="font-style:italic;color:#7a6a95;">(due ${fmtDate(inst.due_date)})</em>` : '';
          return `<div class="rpf-pf-split-row">
            <div class="rpf-pf-split-label">Payment ${i + 1}${dateLabel}</div>
            <div class="rpf-pf-split-amount">${esc(fmtAmt(inst.amount) || 'Amount not set')}</div>
          </div>`;
        }).join('');
        const total = insts.reduce((sum, inst) => sum + (parseFloat(inst.amount) || 0), 0);
        if (total > 0) feeTotal = `<div class="rpf-pf-split-total"><span>Total</span><span>${fmtAmt(String(total))}</span></div>`;
        if (s.split_allow_upfront) feeRows += `<div class="rpf-pf-split-upfront"><em>You may also pay the full amount upfront.</em></div>`;
      } else {
        feeRows = `<div class="rpf-pf-none">Payment amounts have not been configured yet.</div>`;
      }
    }

    const discountBlocks = [];
    if (s.sibling_discount_enabled) {
      const facts = [
        s.sibling_first_child ? discountFact('First performer fee', fmtAmt(s.sibling_first_child)) : '',
        s.sibling_additional ? discountFact('Additional performer fee', `${fmtAmt(s.sibling_additional)}${s.sibling_by_household ? ' per household' : ''}`) : '',
      ].filter(Boolean).join('');
      discountBlocks.push(discountCard({
        name: 'pf_sibling_discount',
        fieldName: 'Same immediate family, more than one performer',
        title: 'Same immediate family, more than one performer',
        description: 'Choose this if another performer from your immediate family is also registered for this show.',
        facts,
        extra: `<div class="rpf-form-group" style="margin:0;">
          <label class="rpf-label" style="font-size:0.75rem;">Other performer names</label>
          <textarea class="rpf-input" name="pf_sibling_performer_names" data-field-name="Other performer names" rows="2" placeholder="List the other performer names in your immediate family..."></textarea>
        </div>`,
      }));
    }
    if (s.volunteer_discount_enabled) {
      const facts = [
        s.volunteer_discount ? discountFact('Discount', `${fmtAmt(s.volunteer_discount)} off`) : '',
        s.volunteer_hours ? discountFact('Volunteer time', `${s.volunteer_hours} hours`) : '',
      ].filter(Boolean).join('');
      discountBlocks.push(discountCard({
        name: 'pf_volunteer_discount',
        fieldName: 'Someone in our family can volunteer',
        title: 'Someone in our family can volunteer',
        description: 'Volunteering keeps community theatre going. Never helped out before? No worries, we will teach you everything.',
        facts,
        extra: `<div class="rpf-form-group" style="margin:0;">
          <label class="rpf-label" style="font-size:0.75rem;">Volunteer name</label>
          <input type="text" class="rpf-input" name="pf_volunteer_name" data-field-name="Volunteer name" placeholder="Who will volunteer?" />
        </div>`,
      }));
    }
    if (s.scholarship_enabled) {
      const note = s.scholarship_note ? esc(s.scholarship_note) : 'Contact the production team for details.';
      discountBlocks.push(discountCard({
        name: 'pf_scholarship_request',
        fieldName: 'I need help with fees',
        title: 'I need help with fees',
        description: 'Choose this if you would like the production team to follow up about financial assistance.',
        facts: `<div class="rpf-pf-discount-fact"><span>Next step</span><span>${note}</span></div>`,
      }));
    }

    const discountsHtml = discountBlocks.length ? `
      <hr class="rpf-pf-divider" />
      <div class="rpf-pf-block">
        <div class="rpf-pf-block-title">Discounts &amp; Fee Reductions</div>
        <div class="rpf-pf-help-copy">Check anything that applies. We will review it before confirming the final amount.</div>
        <div class="rpf-pf-discount-list">${discountBlocks.join('')}</div>
      </div>` : '';

    const instrHtml = s.instructions ? `
      <hr class="rpf-pf-divider" />
      <div class="rpf-pf-block rpf-pf-instructions">
        <div class="rpf-pf-block-title">How to pay</div>
        <div class="rpf-pf-text">${subTokens(s.instructions)}</div>
      </div>` : '';

    const defaultAck = `<p>I have read and understood the production fee structure, payment schedule, and financial policies outlined above.</p><p>I agree to meet all payment obligations as described, and I understand that participation in {{show_name}} is contingent on compliance with these payment expectations.</p>`;
    const ackRaw = template?.agreementText || defaultAck;
    const ackHtml = `<div style="margin-top:0.25rem;">
      <div class="rpf-pf-text" style="margin-bottom:0.6rem;">${subTokens(ackRaw)}</div>
      <label class="rpf-agree-row"><input type="checkbox" name="pf_ack" data-field-name="Payment expectations acknowledged" required /><span>I agree to the payment expectations and policies outlined above.<span class="rpf-req"> *</span></span></label>
    </div>`;

    return `<div class="rpf-pf">
      <div class="rpf-pf-block">
        <div class="rpf-pf-block-title">Production Fee</div>
        ${feeRows}
        ${feeTotal}
      </div>
      ${discountsHtml}
      ${instrHtml}
      <hr class="rpf-pf-divider" />
      ${ackHtml}
      ${age !== null ? `<input type="hidden" name="pf_signer_age" value="${age}" />` : ''}
    </div>`;
  }

  // ── rpfRenderField — single field string → HTML ──────────────────────────────
  function rpfRenderField(fieldStr) {
    const raw = String(fieldStr).trim();

    if (raw === '{cast-agreement}')       return rpfRenderCastAgreementSection(getFormTemplate('cast_agreement'));
    if (raw === '{media-release}')        return rpfRenderMediaReleaseSection(getFormTemplate('media_release'));
    if (raw === '{code-of-conduct}')      return rpfRenderCodeOfConductSection(getFormTemplate('code_of_conduct'));
    if (raw === '{medical-treatment-auth}')  return rpfRenderMedicalTreatmentAuthSection(getFormTemplate('medical_treatment_auth'));
    if (raw === '{travel-permission}')    return rpfRenderTravelPermissionSection(getFormTemplate('transportation_waiver'));
    if (raw === '{physical-performance}') return rpfRenderPhysicalPerformanceSection(getFormTemplate('physical_activity_waiver'));
    if (raw === '{production-fee}')       return rpfRenderProductionFeeSection(getFormTemplate('production_fee'));
    if (raw === '{costume-measurements}') return rpfRenderCostumeMeasurementsSection(getFormTemplate('costume_measurements'));

    if (raw.startsWith('{section}')) {
      const title = raw.slice(9).trim();
      if (/^signature$/i.test(title) || /final acknowledgement/i.test(title)) return '';
      return `<div class="rpf-form-section-divider">${esc(title)}</div>`;
    }

    if (raw === '{pickup-add}') {
      return `<div class="rpf-form-group" data-rpf-solo="1"><button type="button" class="rpf-pickup-add-btn" onclick="rpfAddPickupPerson(this)">+ Add another person</button></div>`;
    }

    const isMinorToggle = raw.startsWith('{minor-toggle}');
    if (isMinorToggle) {
      const label = raw.slice(14).replace(/\s*\*$/, '').trim();
      const _age = rpfCalcAge(_prefill?.date_of_birth);
      const _checked = _age !== null && _age < 19;
      return `<div class="rpf-form-group"><label class="rpf-solo-toggle-row"><input type="checkbox" data-rpf-minor-toggle="1"${_checked ? ' checked' : ''} data-field-name="${esc(label)}" onchange="rpfToggleMinorFields(this)" /><span class="rpf-solo-toggle-label">${esc(label)}</span></label></div>`;
    }

    const isSoloToggle = raw.startsWith('{solo-toggle}');
    if (isSoloToggle) {
      const label = raw.slice(13).replace(/\s*\*$/, '').trim();
      const _age = rpfCalcAge(_prefill?.date_of_birth);
      const _checked = _age !== null && _age >= 19;
      return `<div class="rpf-form-group"><label class="rpf-solo-toggle-row"><input type="checkbox"${_checked ? ' checked' : ''} data-field-name="${esc(label)}" onchange="rpfToggleSoloPickup(this)" /><span class="rpf-solo-toggle-label">${esc(label)}</span></label></div>`;
    }

    const isSolo  = raw.startsWith('{solo}');
    const isMinor = raw.startsWith('{minor}');
    const afterPrefix = isSolo ? raw.slice(6) : isMinor ? raw.slice(7) : raw;
    const isGuard = afterPrefix.startsWith('{guard}');
    const stripped = isGuard ? afterPrefix.slice(7) : afterPrefix;

    const isRequired = stripped.endsWith('*');
    const label = stripped.replace(/\s*\*$/, '').trim();
    if (/\bsignature\b/i.test(label)) return '';

    const pickupMatch = label.match(/^Authorised pickup (\d+) (full name|relationship to performer|phone number)$/i);
    const pickupPerson = pickupMatch?.[1] || '';
    const pickupPart   = (pickupMatch?.[2] || '').toLowerCase();
    const pickupDivider = pickupPart === 'full name'
      ? `<div class="rpf-pickup-person-heading"${isSolo ? ' data-rpf-solo="1"' : ''}>Person ${pickupPerson}</div>`
      : '';
    const pickupClass = pickupMatch
      ? ` rpf-pickup-field${pickupPart === 'phone number' ? ' rpf-pickup-field--last' : ''}`
      : '';
    const displayLabel = pickupMatch
      ? (pickupPart === 'full name' ? 'Full name' : pickupPart === 'relationship to performer' ? 'Relationship to performer' : 'Phone number')
      : label;

    const type = rpfFieldType(label);
    const req  = isRequired ? `<span class="rpf-req"> *</span>` : '';
    const val  = rpfPrefillValue(label.toLowerCase(), _prefill);
    const prefilled = val ? ' rpf-prefilled' : '';

    const soloAttr  = isSolo  ? ' data-rpf-solo="1"' : '';
    const minorAttr = isMinor ? ' data-rpf-minor="1" style="display:none"' : '';
    const guardAttr = isGuard ? ' data-rpf-guard="1" style="display:none"' : '';
    const wrapAttrs = soloAttr + minorAttr + guardAttr;

    // Medical / accessibility reveal pattern
    const medicalReveal = {
      allergies: { check: 'Any allergies?', details: 'Tell us about allergies, reactions, triggers, and what we should do if they happen.' },
      medications: { check: 'Any medications?', details: 'Tell us what they take, when they take it, and anything the team should know.' },
      'medical conditions': { check: 'Any medical conditions we should know about?', details: 'Tell us what the production team needs to know to keep them safe and supported.' },
    }[label.toLowerCase()];
    const supportReveal = /accessibility|accommodation/i.test(label)
      ? { check: 'Does the performer need accessibility or accommodation support?', details: 'Tell us what would help them participate fully.' }
      : null;

    let fieldHtml;
    if (medicalReveal || supportReveal) {
      const reveal = medicalReveal || supportReveal;
      const fieldName = label.toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_|_$/g, '');
      fieldHtml = `<div class="rpf-form-group${pickupClass}"${wrapAttrs}>
        <div class="rpf-medical-reveal">
          <label class="rpf-medical-toggle">
            <input type="checkbox" name="${esc(fieldName)}_has" data-field-name="${esc(label)}_has" />
            <span>${esc(reveal.check)}${req}</span>
          </label>
          <div class="rpf-medical-details">
            <label class="rpf-label">${esc(reveal.details)}</label>
            <textarea class="rpf-input" name="${esc(fieldName)}_details" data-field-name="${esc(label)}" rows="3" placeholder="Add details here..."></textarea>
          </div>
        </div>
      </div>`;
    } else if (type === 'checkbox') {
      fieldHtml = `<div class="rpf-form-group${pickupClass}"${wrapAttrs}>
        <label class="rpf-agree-row"><input type="checkbox" data-field-name="${esc(label)}"${isRequired ? ' required' : ''} /><span>${esc(displayLabel)}${req}</span></label>
      </div>`;
    } else if (type === 'upload') {
      fieldHtml = `<div class="rpf-form-group${pickupClass}"${wrapAttrs}>
        <label class="rpf-label">${esc(displayLabel)}${req}</label>
        <div class="rpf-upload">
          <div class="rpf-upload-hint">Drop your file here, or <span style="text-decoration:underline;cursor:pointer;">browse</span></div>
          <div class="rpf-upload-sub">JPG, PNG or PDF. Max 10 MB</div>
        </div>
      </div>`;
    } else if (type === 'textarea') {
      fieldHtml = `<div class="rpf-form-group${pickupClass}"${wrapAttrs}>
        <label class="rpf-label">${esc(displayLabel)}${req}</label>
        <textarea class="rpf-input${prefilled}" data-field-name="${esc(label)}" placeholder="${esc(label)}...">${esc(val)}</textarea>
      </div>`;
    } else {
      const isDob = type === 'date' && /date of birth|birth date/.test(label.toLowerCase());
      const dobAttr  = isDob ? ` data-rpf-dob="1" oninput="rpfCheckGuardianFields(this)" onchange="rpfCheckGuardianFields(this)"` : '';
      const ageNote  = isDob
        ? `<div class="rpf-age-note" data-rpf-age-note${rpfCalcAge(val) ? '' : ' style="display:none"'}>${rpfCalcAge(val) !== null ? `Age today: ${rpfCalcAge(val)} ${rpfCalcAge(val) === 1 ? 'year old' : 'years old'}` : ''}</div>`
        : '';
      const isSig    = /\bsignature\b/i.test(label);
      const sigWrap  = isSig ? ' rpf-sig-field-wrap' : '';
      const sigEvent = isSig ? ' oninput="rpfUpdateSigPreview(this)"' : '';
      const ph       = type === 'date' ? '' : `placeholder="${esc(label)}..."`;
      fieldHtml = `<div class="rpf-form-group${pickupClass}${sigWrap}"${wrapAttrs}>
        <label class="rpf-label">${esc(displayLabel)}${req}</label>
        <input type="${type}" class="rpf-input${prefilled}" data-field-name="${esc(label)}" ${ph} value="${esc(val)}"${dobAttr}${sigEvent} />
        ${ageNote}
      </div>`;
    }
    return pickupDivider + fieldHtml;
  }

  // ── Final agreement section ──────────────────────────────────────────────────
  function rpfRenderFinalAgreementSection() {
    const age = rpfCalcAge(_prefill?.date_of_birth);
    const isMinor = age !== null && age < 19;
    const ageUnknown = age === null;
    const perfName = _prefill ? [_prefill.preferred_name || _prefill.first_name || '', _prefill.last_name || ''].filter(Boolean).join(' ') : '';
    const prodName = _prod?.title || 'this production';

    const groupTermMap = {
      'Core Registration': 'registration information',
      'Agreements & Consent': 'agreements and permissions',
      'Costumes': 'costume and appearance details',
      'Programme': 'programme details',
      'Production Fees': 'payment expectations',
    };
    const activeGroups = _rpfSections.filter(g => !g.finalAgreement);
    const terms = activeGroups.map(g => groupTermMap[g.name] || g.name.toLowerCase());
    const termStr = terms.length <= 1
      ? (terms[0] || 'registration materials')
      : terms.slice(0, -1).join(', ') + ', and ' + terms[terms.length - 1];

    const adultSig = `<div class="rpf-mr-sig-block"${isMinor ? ' style="display:none"' : ''}>
      <div class="rpf-mr-sig-row">
        <div class="rpf-mr-sig-field rpf-sig-field-wrap">
          <label>Performer signature<span class="rpf-req"> *</span></label>
          <input type="text" name="final_signer_name" data-field-name="final_signer_name" oninput="rpfUpdateSigPreview(this)"${isMinor ? '' : ' required'} autocomplete="name" value="${esc(perfName)}" />
        </div>
        <div class="rpf-mr-sig-field">
          <label>Date<span class="rpf-req"> *</span></label>
          <input type="date" name="final_signed_date" data-field-name="final_signed_date"${isMinor ? '' : ' required'} value="${rpfTodayInputValue()}" />
        </div>
      </div>
    </div>`;

    const guardianSig = `<div class="rpf-mr-guardian-block"${isMinor || ageUnknown ? '' : ' style="display:none"'}>
      <div class="rpf-mr-guardian-label">Parent / Guardian Signature</div>
      <div class="rpf-mr-sig-block">
        <div class="rpf-mr-sig-row">
          <div class="rpf-mr-sig-field">
            <label>Parent or guardian full name<span class="rpf-req"> *</span></label>
            <input type="text" name="final_guardian_name" data-field-name="final_guardian_name"${isMinor ? ' required' : ''} autocomplete="name" />
          </div>
          <div class="rpf-mr-sig-field">
            <label>Relationship to performer<span class="rpf-req"> *</span></label>
            <input type="text" name="final_guardian_relationship" data-field-name="final_guardian_relationship"${isMinor ? ' required' : ''} />
          </div>
        </div>
        <div class="rpf-mr-sig-row">
          <div class="rpf-mr-sig-field rpf-sig-field-wrap">
            <label>Parent or guardian signature<span class="rpf-req"> *</span></label>
            <input type="text" name="final_guardian_sig" data-field-name="final_guardian_sig" oninput="rpfUpdateSigPreview(this)"${isMinor ? ' required' : ''} />
          </div>
          <div class="rpf-mr-sig-field">
            <label>Date<span class="rpf-req"> *</span></label>
            <input type="date" name="final_guardian_date" data-field-name="final_guardian_date"${isMinor ? ' required' : ''} value="${rpfTodayInputValue()}" />
          </div>
        </div>
      </div>
    </div>`;

    return `<div class="rpf-final-agree">
      <div class="rpf-final-kicker">Final step</div>
      <div class="rpf-final-title">I AGREE</div>
      <div class="rpf-final-copy">By signing below, I confirm that I have reviewed the ${esc(termStr)} for ${esc(prodName)}.</div>
      <div class="rpf-final-agree-box">
        <label class="rpf-agree-row"><input type="checkbox" name="final_all_agree" data-field-name="final_all_agree" required /><span>I have read and agree to the registration terms and confirm the information provided is accurate.<span class="rpf-req"> *</span></span></label>
      </div>
      ${!isMinor ? adultSig : ''}
      ${(isMinor || ageUnknown) ? guardianSig : ''}
    </div>`;
  }

  // ── Navigation ───────────────────────────────────────────────────────────────
  window.rpfGoTo = function(index) {
    if (index < 0 || index >= _rpfSections.length) return;
    const prev = _rpfCurrent;
    if (index > prev) _rpfCompleted.add(prev);
    _rpfCurrent = index;
    rpfUpdateNav(index);
    document.querySelectorAll('.rpf-panel').forEach((p, i) => p.classList.toggle('rpf-active', i === index));
    document.getElementById('rpf-wizard-body')?.scrollTo({ top: 0, behavior: 'smooth' });
    scheduleSave();
  };

  function rpfUpdateNav(current) {
    _rpfSections.forEach((_, i) => {
      const item = document.getElementById(`rpf-left-item-${i}`);
      const dot  = document.getElementById(`rpf-dot-${i}`);
      if (!item || !dot) return;
      const isDone = _rpfCompleted.has(i) && i !== current;
      item.classList.toggle('rpf-active', i === current);
      item.classList.toggle('rpf-done',   isDone);
      dot.textContent = isDone ? '✓' : String(i + 1);
    });
    const activeItem = document.getElementById(`rpf-left-item-${current}`);
    activeItem?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // ── Form data collection ──────────────────────────────────────────────────────
  function collectFormAnswers() {
    const shell = document.getElementById('rpf-root');
    if (!shell) return {};
    const answers = {};
    // Named inputs
    shell.querySelectorAll('input[name], select[name], textarea[name]').forEach(el => {
      const name = el.name;
      if (!name) return;
      if (el.type === 'checkbox') answers[name] = el.checked;
      else if (el.type === 'radio') { if (el.checked) answers[name] = el.value; }
      else answers[name] = el.value;
    });
    // data-field-name elements (unnamed)
    shell.querySelectorAll('[data-field-name]:not([name])').forEach(el => {
      const name = el.dataset.fieldName;
      if (!name) return;
      if (el.tagName === 'INPUT' && el.type === 'checkbox') answers[name] = el.checked;
      else if (el.tagName === 'INPUT' && el.type === 'radio') { if (el.checked) answers[name] = el.value; }
      else answers[name] = el.value;
    });
    return answers;
  }

  function rpfTextForPdf(value) {
    return String(value ?? '')
      .replace(/\u00a0/g, ' ')
      .replace(/[“”]/g, '"')
      .replace(/[‘’]/g, "'")
      .replace(/[–—]/g, '-')
      .replace(/[^\x09\x0A\x0D\x20-\x7E]/g, '')
      .replace(/\s+/g, ' ')
      .trim();
  }

  function rpfPdfEscape(value) {
    return rpfTextForPdf(value).replace(/\\/g, '\\\\').replace(/\(/g, '\\(').replace(/\)/g, '\\)');
  }

  function rpfPdfLabelForField(el) {
    const permRow = el.closest('.rpf-mr-perm-row');
    if (permRow) return rpfTextForPdf(permRow.querySelector('.rpf-mr-perm-label')?.textContent || el.dataset.fieldName || el.name || 'Answer');
    const wrap = el.closest('.rpf-form-group, .rpf-mr-sig-field, .rpf-final-agree-box');
    const label = wrap?.querySelector('.rpf-label, label, .rpf-mr-guardian-label');
    const raw = label?.textContent || el.dataset.fieldName || el.name || 'Answer';
    return rpfTextForPdf(raw).replace(/\s*\*\s*/g, '').replace(/\s+/g, ' ');
  }

  function rpfPdfValueForField(el) {
    if (el.type === 'checkbox') return el.checked ? 'Yes' : 'No';
    if (el.type === 'radio') {
      const selected = document.querySelector(`input[type="radio"][name="${CSS.escape(el.name)}"]:checked`);
      if (!selected) return 'N/A';
      return rpfTextForPdf(selected.closest('label')?.textContent || selected.value || 'Selected');
    }
    if (el.type === 'file') return el.files?.length ? Array.from(el.files).map(f => f.name).join(', ') : 'N/A';
    return rpfTextForPdf(el.value || 'N/A');
  }

  function rpfPerformerNameForPdf() {
    const fromPrefill = _prefill ? [_prefill.preferred_name || _prefill.first_name || '', _prefill.last_name || ''].filter(Boolean).join(' ') : '';
    const collected = collectFormAnswers();
    return rpfTextForPdf(fromPrefill || [collected['Preferred name'] || collected['Legal first name'] || '', collected['Legal last name'] || ''].filter(Boolean).join(' ') || 'Performer');
  }

  function rpfContractDateForPdf() {
    const collected = collectFormAnswers();
    return rpfTextForPdf(collected.final_guardian_date || collected.final_signed_date || rpfTodayInputValue());
  }

  function rpfContractTitleForPdf() {
    return [
      _org?.name || _org?.abbreviation || 'Organisation',
      _prod?.title || 'Production',
      rpfPerformerNameForPdf(),
      rpfContractDateForPdf(),
    ].map(rpfTextForPdf).filter(Boolean).join(' - ');
  }

  function rpfContractFileSlugForPdf(title) {
    return String(title || 'registration-contract')
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-|-$/g, '')
      .slice(0, 120) || 'registration-contract';
  }

  function rpfSectionWordingForPdf(section) {
    const selectors = [
      '.rpf-section-text',
      '.rpf-form-section-divider',
      '.rpf-coc-section-title',
      '.rpf-coc-section-body',
      '.rpf-mr-section-label',
      '.rpf-mr-text',
      '.rpf-mr-perm-label',
      '.rpf-pf-block-title',
      '.rpf-pf-row',
      '.rpf-pf-split-row',
      '.rpf-pf-none',
      '.rpf-pf-text',
      '.rpf-final-copy',
      '.rpf-final-agree-box span',
      '.rpf-mr-guardian-label',
      '.rpf-cm-hint',
      '.rpf-upload-sub',
    ];
    const seen = new Set();
    const wording = [];
    section.querySelectorAll(selectors.join(',')).forEach(node => {
      if (node.closest('.rpf-csd-dropdown')) return;
      const text = rpfTextForPdf(node.textContent);
      if (!text || seen.has(text)) return;
      seen.add(text);
      wording.push(text);
    });
    return wording;
  }

  function rpfSectionAnswersForPdf(section) {
    const rows = [];
    const seen = new Set();
    const radioGroups = new Set();
    section.querySelectorAll('input, select, textarea').forEach(el => {
      if (el.disabled) return;
      if (el.type === 'hidden') return;
      if (el.closest('.rpf-csd-dropdown')) return;
      if (el.type === 'radio') {
        if (!el.name || radioGroups.has(el.name)) return;
        radioGroups.add(el.name);
      }
      const label = rpfPdfLabelForField(el);
      const value = rpfPdfValueForField(el);
      const key = `${label}::${el.name || el.dataset.fieldName || el.type}`;
      if (seen.has(key)) return;
      seen.add(key);
      rows.push({ label, value });
    });
    return rows;
  }

  function rpfCollectAnswerRowsForPdf() {
    const shell = document.getElementById('rpf-root');
    const title = rpfContractTitleForPdf();
    const doc = {
      title,
      fileSlug: rpfContractFileSlugForPdf(title),
      generatedAt: new Date().toLocaleString('en-CA'),
      organisation: rpfTextForPdf(_org?.name || _org?.abbreviation || 'Organisation'),
      production: rpfTextForPdf(_prod?.title || 'Production'),
      performer: rpfPerformerNameForPdf(),
      date: rpfContractDateForPdf(),
      sections: [],
    };
    if (!shell) return doc;
    shell.querySelectorAll('.rpf-panel').forEach(panel => {
      const group = rpfTextForPdf(panel.querySelector('.rpf-step-title')?.textContent);
      panel.querySelectorAll('.rpf-section').forEach(section => {
        const title = rpfTextForPdf(section.querySelector('.rpf-section-head span')?.textContent || group || 'Section');
        doc.sections.push({
          group,
          title,
          wording: rpfSectionWordingForPdf(section),
          answers: rpfSectionAnswersForPdf(section),
        });
      });
    });
    return doc;
  }

  function rpfWrapPdfLine(text, max = 78) {
    const words = rpfTextForPdf(text).split(/\s+/).filter(Boolean);
    const lines = [];
    let line = '';
    words.forEach(word => {
      const next = line ? `${line} ${word}` : word;
      if (next.length > max && line) {
        lines.push(line);
        line = word;
      } else {
        line = next;
      }
    });
    if (line) lines.push(line);
    return lines.length ? lines : [''];
  }

  function rpfPdfLineItemsForContract(doc) {
    const items = [];
    const add = (text, opts = {}) => items.push(Object.assign({ text: rpfTextForPdf(text), size: 10, font: 'F1', indent: 0, gap: 2 }, opts));
    add(doc.title, { size: 17, font: 'F2', gap: 12 });
    add('Registration Contract Record', { size: 11, font: 'F2', gap: 10 });
    add(`Organisation: ${doc.organisation}`);
    add(`Production: ${doc.production}`);
    add(`Performer: ${doc.performer}`);
    add(`Date: ${doc.date}`);
    add(`Generated: ${doc.generatedAt}`, { gap: 12 });
    add('This document records the complete registration wording presented to the performer/guardian and the submitted responses captured by Build The Show.', { gap: 14 });

    (doc.sections || []).forEach((section, index) => {
      add(`${index + 1}. ${section.group ? `${section.group} - ` : ''}${section.title}`, { size: 12, font: 'F2', gap: 6 });
      if (section.wording?.length) {
        add('Contract wording shown:', { font: 'F2', gap: 3 });
        section.wording.forEach(text => add(text, { indent: 14, gap: 3 }));
      }
      if (section.answers?.length) {
        add('Submitted responses:', { font: 'F2', gap: 3 });
        section.answers.forEach(row => add(`${row.label}: ${row.value}`, { indent: 14, gap: 3 }));
      }
      if (!section.wording?.length && !section.answers?.length) add('No wording or answers were captured for this section.', { indent: 14, gap: 8 });
      add('', { gap: 6 });
    });
    return items;
  }

  function rpfBuildAnswersPdf(data) {
    const doc = Array.isArray(data)
      ? { title: rpfContractTitleForPdf(), generatedAt: new Date().toLocaleString('en-CA'), organisation: _org?.name || _org?.abbreviation || 'Organisation', production: _prod?.title || 'Production', performer: rpfPerformerNameForPdf(), date: rpfContractDateForPdf(), sections: [{ group: 'Registration', title: 'Submitted Answers', wording: [], answers: data }] }
      : data;
    const lineItems = rpfPdfLineItemsForContract(doc);
    const pages = [[]];
    let y = 742;
    lineItems.forEach(item => {
      const maxChars = Math.max(28, Math.floor((512 - item.indent) / (item.size * 0.52)));
      const wrapped = item.text ? rpfWrapPdfLine(item.text, maxChars) : [''];
      wrapped.forEach((line, i) => {
        const lineHeight = Math.max(12, item.size * 1.35);
        if (y - lineHeight < 48) {
          pages.push([]);
          y = 742;
        }
        pages[pages.length - 1].push(Object.assign({}, item, { text: line, y }));
        y -= lineHeight;
        if (i === wrapped.length - 1) y -= item.gap || 0;
      });
    });
    const objects = ['<< /Type /Catalog /Pages 2 0 R >>'];
    const pageRefs = [];
    objects.push(null);
    objects.push('<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica >>');
    objects.push('<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica-Bold >>');
    pages.forEach(pageLines => {
      const stream = pageLines.map(line => `BT\n/${line.font} ${line.size} Tf\n${50 + (line.indent || 0)} ${line.y} Td\n(${rpfPdfEscape(line.text)}) Tj\nET`).join('\n');
      const streamObjNum = objects.length + 2;
      const pageObjNum = objects.length + 1;
      objects.push(`<< /Type /Page /Parent 2 0 R /MediaBox [0 0 612 792] /Resources << /Font << /F1 3 0 R /F2 4 0 R >> >> /Contents ${streamObjNum} 0 R >>`);
      objects.push(`<< /Length ${stream.length} >>\nstream\n${stream}\nendstream`);
      pageRefs.push(`${pageObjNum} 0 R`);
    });
    objects[1] = `<< /Type /Pages /Kids [${pageRefs.join(' ')}] /Count ${pageRefs.length} >>`;

    let pdf = '%PDF-1.4\n';
    const offsets = [0];
    objects.forEach((obj, idx) => {
      offsets[idx + 1] = pdf.length;
      pdf += `${idx + 1} 0 obj\n${obj}\nendobj\n`;
    });
    const xref = pdf.length;
    pdf += `xref\n0 ${objects.length + 1}\n0000000000 65535 f \n`;
    offsets.slice(1).forEach(offset => { pdf += `${String(offset).padStart(10, '0')} 00000 n \n`; });
    pdf += `trailer\n<< /Size ${objects.length + 1} /Root 1 0 R >>\nstartxref\n${xref}\n%%EOF`;
    return pdf;
  }

  window.rpfDownloadAnswersPdf = function() {
    const doc = window._rpfSubmittedAnswerRows || rpfCollectAnswerRowsForPdf();
    const pdf = rpfBuildAnswersPdf(doc);
    const slug = doc.fileSlug || rpfContractFileSlugForPdf(doc.title);
    const blob = new Blob([pdf], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${slug}.pdf`;
    document.body.appendChild(a);
    a.click();
    a.remove();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  };

  // ── Auto-save ─────────────────────────────────────────────────────────────────
  function scheduleSave(delay = 2000) {
    clearTimeout(_saveTimer);
    _saveTimer = setTimeout(doSave, delay);
  }

  async function doSave() {
    if (!_applicant?.id) return;
    try {
      const collected = collectFormAnswers();
      const merged = Object.assign({}, _applicant.custom_answers || {}, collected);
      const { error } = await sb.from('audition_applications').update({ custom_answers: merged }).eq('id', _applicant.id);
      if (error) throw error;
      _applicant.custom_answers = merged;
      showSavedIndicator();
    } catch (e) {
      console.warn('[BTS] autosave failed', e);
    }
  }

  // ── Final submit ──────────────────────────────────────────────────────────────
  window.rpfSubmit = async function() {
    const btn = document.querySelector('.rpf-submit-btn');
    if (btn) { btn.disabled = true; btn.textContent = 'Submitting...'; }

    clearTimeout(_saveTimer);
    try {
      if (!_applicant?.id) throw new Error('Missing applicant record for registration submit.');
      const pdfRows = rpfCollectAnswerRowsForPdf();
      const collected = collectFormAnswers();
      const merged = Object.assign({}, _applicant?.custom_answers || {}, collected, {
        __bts_registration_complete: true,
        __bts_registration_submitted_at: new Date().toISOString(),
      });

      const { error } = await sb.from('audition_applications').update({ custom_answers: merged }).eq('id', _applicant.id);
      if (error) throw error;
      _applicant.custom_answers = merged;
      window._rpfSubmittedAnswerRows = pdfRows;
      showSavedIndicator();

      // Mark all nav items done
      _rpfSections.forEach((_, i) => {
        const item = document.getElementById(`rpf-left-item-${i}`);
        const dot  = document.getElementById(`rpf-dot-${i}`);
        if (item) { item.classList.remove('rpf-active'); item.classList.add('rpf-done'); }
        if (dot)  dot.textContent = '✓';
      });

      // Show success screen
      const body = document.getElementById('rpf-wizard-body');
      if (body) {
        body.innerHTML = `<div class="rpf-success">
          <div class="rpf-success-kicker">Registration Complete</div>
          <div class="rpf-success-big">You're&nbsp;in.</div>
          <div class="rpf-success-show-badge">${esc(_prod?.title || 'Production')}</div>
          <div class="rpf-success-copy">Your registration has been submitted. The production team will be in touch with next steps.</div>
          <div class="rpf-success-card">
            <div class="rpf-success-title">Check your inbox.</div>
            <div class="rpf-success-body">A confirmation is on its way. If you do not see it within a few minutes, check your spam folder.</div>
          </div>
          <div class="rpf-success-actions">
            <button type="button" class="rpf-download-answers-btn" onclick="rpfDownloadAnswersPdf()">Download PDF of answers</button>
          </div>
        </div>`;
      }
    } catch (err) {
      console.error('[BTS] submit failed', err);
      if (btn) { btn.disabled = false; btn.textContent = 'Submit Registration'; }
      alert('Something went wrong submitting your registration. Please try again or contact the production team.');
    }
  };

  // ── Main render ───────────────────────────────────────────────────────────────
  function renderForm() {
    const savedSettings = _regSettings || {};
    const formTemplates = savedSettings.form_templates || {};
    _formTemplates = formTemplates;

    // Determine which defs are enabled
    const enabledDefs = REGISTRATION_FORM_TEMPLATE_DEFS.filter(def => {
      const groupKey = `form_group_${String(def.group || '').toLowerCase().replace(/[^a-z0-9]+/g, '_')}`;
      const groupOn = savedSettings[groupKey] !== false;
      if (!groupOn) return false;
      const defKey = `form_${def.key}`;
      if (savedSettings[defKey] !== undefined) return savedSettings[defKey] !== false;
      return def.defaultOn;
    });

    // Build section groups
    const groupOrder = [];
    const groupMap = {};
    enabledDefs.forEach(def => {
      if (!groupMap[def.group]) { groupMap[def.group] = []; groupOrder.push(def.group); }
      groupMap[def.group].push(def);
    });
    const groups = groupOrder.map(name => ({ name, defs: groupMap[name] }));
    groups.push({ name: 'Final Agreement', finalAgreement: true, defs: [{ title: 'I Agree' }] });
    _rpfSections = groups;
    _rpfCurrent  = 0;
    _rpfCompleted = new Set();

    const prodName   = _prod?.title || 'Production';
    const posterUrl  = _prod?.poster_url || '';
    const deadline   = savedSettings?.due_date || '';
    const deadlineLabel = deadline
      ? `Due ${new Date(deadline).toLocaleDateString('en-CA', { month: 'short', day: 'numeric', year: 'numeric' })}`
      : 'Registration Open';

    const hasPrefill = _prefill && (_prefill.first_name || _prefill.email);
    const bgColorMap = { '#476aaa': '#e8ecf4', '#d1523d': '#fce8e6', '#769e7b': '#eaf4ec', '#ca7ea7': '#faeef6', '#efab45': '#fef5e8', '#78bbd4': '#e8f5fa' };

    // Sidebar nav items
    const navItemsHtml = groups.map((g, i) => `
      <div class="rpf-left-item${i === 0 ? ' rpf-active' : ''}" id="rpf-left-item-${i}" onclick="rpfGoTo(${i})">
        <div class="rpf-left-item-main">
          <div class="rpf-left-dot" id="rpf-dot-${i}">${i + 1}</div>
          <div class="rpf-left-label">${esc(g.name)}</div>
        </div>
        <div class="rpf-left-sublist" id="rpf-left-sub-${i}">
          ${g.defs.map((def, di) => `<div class="rpf-left-subitem" id="rpf-sub-${i}-${di}"><span class="rpf-left-subdot">&#10003;</span><span>${esc(def.title)}</span></div>`).join('')}
        </div>
      </div>`).join('');

    // Panels
    const panelsHtml = groups.map((g, i) => {
      const isLast = i === groups.length - 1;
      const sectionsHtml = g.defs.map((def, di) => {
        if (g.finalAgreement) {
          return `<div class="rpf-section" style="--rpf-head:#572e88;--rpf-bg:#f4effa;">
            <div class="rpf-section-head"><span>Final Agreement</span></div>
            <div class="rpf-section-body">${rpfRenderFinalAgreementSection()}</div>
          </div>`;
        }
        const template = _formTemplates[def.key] || null;
        const fields   = registrationFormVisibleFields(template?.fields?.length ? template.fields : def.defaultFields || []);
        const intro    = template?.intro ? subTokens(template.intro) : '';
        const bodyHtml = def.key === 'cast_agreement'
          ? rpfRenderCastAgreementSection(template)
          : fields.map(f => rpfRenderField(f)).join('');
        const bgColor  = bgColorMap[def.color] || '#ebe6f1';
        return `<div class="rpf-section" data-rpf-panel="${i}" data-rpf-si="${di}" style="--rpf-head:${esc(def.color)};--rpf-bg:${bgColor};">
          <div class="rpf-section-head"><span>${esc(def.title)}</span></div>
          ${intro ? `<div class="rpf-step-sub rpf-section-text" style="padding:0.75rem 1.25rem 0;">${intro}</div>` : ''}
          <div class="rpf-section-body">${bodyHtml}</div>
        </div>`;
      }).join('');

      return `<div class="rpf-panel${i === 0 ? ' rpf-active' : ''}" id="rpf-panel-${i}">
        <div class="rpf-step-title">${esc(g.name)}</div>
        ${hasPrefill && i === 0 ? `<div class="rpf-prefill-badge">&#10003; Pre-filled from your profile</div>` : ''}
        ${sectionsHtml}
        <div class="rpf-nav">
          <button class="rpf-btn-back" style="${i === 0 ? 'visibility:hidden' : ''}" onclick="rpfGoTo(${i - 1})">&#8592; Back</button>
          <div class="rpf-autosave"><div class="rpf-autosave-dot"></div> Saved automatically</div>
          ${isLast
            ? `<button class="rpf-btn-next rpf-submit-btn" onclick="rpfSubmit()">Submit Registration</button>`
            : `<button class="rpf-btn-next" onclick="rpfGoTo(${i + 1})">Next &#8594;</button>`
          }
        </div>
      </div>`;
    }).join('');

    const orgLogoHtml = _org?.logo_url
      ? `<img src="${esc(_org.logo_url)}" alt="${esc(_org.name || '')}" />`
      : `<div class="rpf-left-logo-name">${esc(_org?.name || _org?.abbreviation || 'Build The Show')}</div>`;

    const posterHtml = posterUrl
      ? `<img src="${esc(posterUrl)}" alt="${esc(prodName)}" />`
      : `<div class="rpf-card-poster-ph">&#127917;</div>`;
    const performerFirst = _prefill?.preferred_name || _prefill?.first_name || '';
    const performerLast = _prefill?.last_name || '';
    const performerName = [performerFirst, performerLast].filter(Boolean).join(' ').trim();
    const performerCardHtml = performerName && typeof window.renderCastingCard === 'function'
      ? `<div class="rpf-card-inshow">${window.renderCastingCard({
          first_name: performerFirst,
          last_name: performerLast,
          headshot_url: _prefill?.headshot_url || '',
          character_name: 'Cast Member'
        }, { variant: 'inTheShow' })}</div>`
      : '';

    const root = document.getElementById('rpf-root');
    root.innerHTML = `<div class="rpf-shell">
      <div class="rpf-left-bar">
        <div class="rpf-left-logo">${orgLogoHtml}</div>
        <div class="rpf-left-cards">
          <div class="rpf-card-poster">${posterHtml}</div>
          ${performerCardHtml}
        </div>
        <div class="rpf-left-info">
          <div class="rpf-left-prod-name">${esc(prodName)}</div>
          <div class="rpf-left-deadline">${esc(deadlineLabel)}</div>
        </div>
        <div class="rpf-left-nav">
          <div class="rpf-left-nav-heading">Sections</div>
          ${navItemsHtml}
        </div>
      </div>
      <div class="rpf-main" id="rpf-wizard-body">
        <div class="rpf-page">
          <div class="rpf-card">
            <div class="rpf-body">${panelsHtml}</div>
          </div>
        </div>
      </div>
    </div>`;

    // Post-render hooks
    requestAnimationFrame(() => requestAnimationFrame(() => {
      if (typeof window.fitCastingCardNames === 'function') window.fitCastingCardNames(root);
      root.querySelectorAll('[data-rpf-dob]').forEach(el => rpfCheckGuardianFields(el));
      root.querySelectorAll('.rpf-sig-field-wrap input').forEach(el => rpfUpdateSigPreview(el));
      root.querySelectorAll('.rpf-solo-toggle-row input').forEach(cb => { if (cb.checked) rpfToggleSoloPickup(cb); });
      root.querySelectorAll('[data-rpf-minor-toggle]').forEach(cb => rpfToggleMinorFields(cb));
    }));

    // Bind autosave on any input/change
    root.addEventListener('input', () => scheduleSave(1500), true);
    root.addEventListener('change', () => scheduleSave(600), true);
  }

  // ── Data loading & boot ───────────────────────────────────────────────────────
  function buildPrefill(applicant) {
    if (!applicant) return null;
    const ca = applicant.custom_answers || {};
    const nameParts = String(applicant.name || '').trim().split(/\s+/);
    return {
      first_name:     applicant.first_name  || ca['Legal first name'] || nameParts[0] || '',
      last_name:      applicant.last_name   || ca['Legal last name']  || nameParts.slice(1).join(' ') || '',
      preferred_name: applicant.preferred_name || ca['Preferred name'] || '',
      pronouns:       applicant.pronouns    || ca['Pronouns'] || '',
      date_of_birth:  applicant.dob         || ca['Date of birth'] || '',
      email:          applicant.email       || '',
      phone:          applicant.phone       || ca['Contact phone number'] || ca['Phone'] || '',
      headshot_url:   applicant.headshot_url || '',
      pickup_1_name: ca['Authorised pickup 1 full name'] || ca['Authorized pickup 1 full name'] || ca['Pickup 1 full name'] || '',
      pickup_1_relationship: ca['Authorised pickup 1 relationship to performer'] || ca['Authorized pickup 1 relationship to performer'] || ca['Pickup 1 relationship to performer'] || '',
      pickup_1_phone: ca['Authorised pickup 1 phone number'] || ca['Authorized pickup 1 phone number'] || ca['Pickup 1 phone number'] || '',
      pickup_2_name: ca['Authorised pickup 2 full name'] || ca['Authorized pickup 2 full name'] || ca['Pickup 2 full name'] || '',
      pickup_2_relationship: ca['Authorised pickup 2 relationship to performer'] || ca['Authorized pickup 2 relationship to performer'] || ca['Pickup 2 relationship to performer'] || '',
      pickup_2_phone: ca['Authorised pickup 2 phone number'] || ca['Authorized pickup 2 phone number'] || ca['Pickup 2 phone number'] || '',
    };
  }

  async function boot() {
    if (!_regCode && !_applicantId) {
      showError('No registration code', 'This link is missing a registration code. Please use the link from your invitation email.');
      return;
    }

    // 1. Resolve the same offer identity used by the cast-offer page.
    const applicantSelect = 'id, production_id, name, email, custom_answers, date_conflicts, conflicts';
    let applicant = null;
    if (_applicantId) {
      let byId = sb.from('audition_applications').select(applicantSelect).eq('id', _applicantId);
      if (_productionId) byId = byId.eq('production_id', _productionId);
      const { data, error } = await byId.maybeSingle();
      if (error) throw error;
      applicant = data || null;
    }
    async function findApplicantByOfferKey(key) {
      const { data, error } = await sb
        .from('audition_applications')
        .select(applicantSelect)
        .contains('custom_answers', { [key]: _regCode })
        .limit(1);
      if (error) throw error;
      return data?.[0] || null;
    }
    if (!applicant && _regCode) applicant = await findApplicantByOfferKey(CAST_OFFER_KEYS.code);
    if (!applicant && _regCode) applicant = await findApplicantByOfferKey(CAST_OFFER_KEYS.token);

    let offer = null;
    if (!applicant) {
      const { data: offerMatch, error: offerErr } = await sb
        .from('cast_offers')
        .select('id, production_id, applicant_id, token, code')
        .or(`token.eq.${_regCode},code.eq.${_regCode}`)
        .maybeSingle();
      if (offerErr) throw offerErr;
      offer = offerMatch || null;
    }

    if (!applicant && !offer) {
      showError('Link not found', 'This registration link does not match any active production. It may have expired or been removed. Please contact your production team for a new link.');
      return;
    }
    _offer = offer || {
      id: '',
      production_id: applicant?.production_id || _productionId || '',
      applicant_id: applicant?.id || '',
      token: _regCode,
      code: _regCode,
    };

    // 2. Production
    const { data: prod, error: prodErr } = await sb
      .from('productions')
      .select('id, title, slug, registration_settings, poster_url, start_date, end_date, venue, organization_id')
      .eq('id', _offer.production_id)
      .maybeSingle();

    if (prodErr || !prod) {
      showError('Production not found', 'Unable to load this production. Please contact your production team.');
      return;
    }
    _prod = prod;
    _regSettings = (typeof prod.registration_settings === 'object' && prod.registration_settings) ? prod.registration_settings : {};

    const loadingCopy = document.getElementById('loading-prod-name');
    if (loadingCopy) loadingCopy.textContent = prod.title || '';

    // 3. Organisation
    if (prod.organization_id) {
      const { data: org } = await sb
        .from('organizations')
        .select('name, logo_url, abbreviation')
        .eq('id', prod.organization_id)
        .maybeSingle();
      _org = org || null;
    }

    // 4. Applicant / prefill
    if (applicant) {
      _applicant = applicant;
      _prefill = buildPrefill(_applicant);
    } else if (_offer.applicant_id) {
      const { data: applicantMatch } = await sb
        .from('audition_applications')
        .select(applicantSelect)
        .eq('id', _offer.applicant_id)
        .maybeSingle();
      _applicant = applicantMatch || null;
      _prefill = buildPrefill(_applicant);
    }

    // 5. Render
    document.getElementById('loading-shell').style.display = 'none';
    const root = document.getElementById('rpf-root');
    root.style.display = 'block';
    document.body.classList.add('form-ready');
    document.title = `${prod.title || 'Registration'} | Build The Show`;

    renderForm();
  }

  boot().catch(err => {
    console.error('[BTS] registration boot failed', err);
    showError('Something went wrong', `Unable to load the registration form. ${err?.message || ''}`);
  });

  </script>
