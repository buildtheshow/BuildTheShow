  window.rpfUpdateSigPreview = function(input) {
    const wrap = input.closest('.rpf-sig-field-wrap');
    if (!wrap) return;
    let preview = wrap.querySelector('.rpf-sig-preview');
    if (!preview) {
      preview = document.createElement('div');
      preview.className = 'rpf-sig-preview';
      input.after(preview);
    }
    preview.textContent = input.value;
  };

  window.rpfCsdOpen = function(input) {
    if (!window._rpfCsdClickBound) {
      window._rpfCsdClickBound = true;
      document.addEventListener('click', e => {
        if (!e.target.closest('.rpf-csd')) {
          document.querySelectorAll('.rpf-csd-dropdown:not([hidden])').forEach(d => { d.hidden = true; });
        }
      });
    }
    const wrap = input.closest('.rpf-csd');
    if (!wrap) return;
    document.querySelectorAll('.rpf-csd-dropdown:not([hidden])').forEach(d => { if (d !== wrap.querySelector('.rpf-csd-dropdown')) d.hidden = true; });
    const dd = wrap.querySelector('.rpf-csd-dropdown');
    if (dd) dd.hidden = false;
  };

  window.rpfCsdFilter = function(input) {
    rpfCsdOpen(input);
    const q = (input.value || '').toLowerCase().trim();
    const wrap = input.closest('.rpf-csd');
    if (!wrap) return;
    const dd = wrap.querySelector('.rpf-csd-dropdown');
    if (!dd) return;
    let anyVisible = false;
    dd.querySelectorAll('.rpf-csd-group').forEach(grp => {
      let grpVisible = false;
      grp.querySelectorAll('.rpf-csd-option').forEach(opt => {
        const match = !q || opt.textContent.toLowerCase().includes(q);
        opt.classList.toggle('rpf-csd-option--hidden', !match);
        if (match) grpVisible = true;
      });
      grp.hidden = !grpVisible;
      if (grpVisible) anyVisible = true;
    });
    const empty = dd.querySelector('.rpf-csd-empty');
    if (empty) empty.style.display = anyVisible ? 'none' : '';
  };

  window.rpfCsdSelect = function(option, value) {
    const wrap = option.closest('.rpf-csd');
    if (!wrap) return;
    const visibleInput = wrap.querySelector('.rpf-csd-input');
    const hiddenInput  = wrap.querySelector('input[type="hidden"]');
    if (visibleInput) visibleInput.value = value;
    if (hiddenInput)  hiddenInput.value  = value;
    visibleInput?.dispatchEvent(new Event('input', { bubbles: true }));
    hiddenInput?.dispatchEvent(new Event('change', { bubbles: true }));
    const dd = wrap.querySelector('.rpf-csd-dropdown');
    if (dd) dd.hidden = true;
    wrap.querySelectorAll('.rpf-csd-option').forEach(o => o.classList.remove('rpf-csd-option--hidden'));
    wrap.querySelectorAll('.rpf-csd-group').forEach(g => { g.hidden = false; });
    const empty = dd?.querySelector('.rpf-csd-empty');
    if (empty) empty.style.display = 'none';
  };

  // ── Field type detection ──────────────────────────────────────────────────────
  function rpfFieldType(label) {
    const n = label.toLowerCase();
    const pickupMatch = n.match(/^authori[sz]ed pickup \d+ (full name|relationship to performer|phone number)$/);
    if (pickupMatch) return pickupMatch[1] === 'phone number' ? 'tel' : 'text';
    if (/upload|headshot|photo/.test(n)) return 'upload';
    if (/date of birth|birth date|signature date/.test(n)) return 'date';
    if (/\bemail\b/.test(n)) return 'email';
    if (/\bphone\b/.test(n)) return 'tel';
    if (/address|bio|notes|instructions|schedule|credits|fun fact|comments|additional|allergies|medications|conditions|accommodations|supports|needs|requests|describe|other|sensitivities|considerations/.test(n)) return 'textarea';
    if (/acknowledged|consent|agree|authoris|commit|release|permission|waiver|policy|confirm|understand|accept/.test(n)) return 'checkbox';
    return 'text';
  }

  // ── Prefill value resolution ──────────────────────────────────────────────────
  function rpfPrefillValue(label, prefill) {
    if (!prefill) return '';
    const n = label.toLowerCase();
    const pickupMatch = n.match(/^authori[sz]ed pickup (\d+) (full name|relationship to performer|phone number)$/);
    if (pickupMatch) return '';
    if (/legal first name|^first name/.test(n))  return prefill.first_name || '';
    if (/legal last name|^last name/.test(n))    return prefill.last_name  || '';
    if (/preferred name/.test(n))                return prefill.preferred_name || '';
    if (/pronoun/.test(n))                       return prefill.pronouns || '';
    if (/date of birth|birth date/.test(n))      return prefill.date_of_birth || '';
    if (/contact email|participant email/.test(n)) return prefill.email || '';
    if (/contact phone/.test(n) && !/guardian/.test(n)) return prefill.phone || '';
    if (/\bphone\b/.test(n) && !/guardian/.test(n)) return prefill.phone || '';
    if (/guardian first name|guardian.*first/.test(n)) return prefill.guardian_first || '';
    if (/guardian last name|guardian.*last/.test(n))   return prefill.guardian_last  || '';
    if (/guardian.*phone/.test(n)) return prefill.guardian_phone || '';
    if (/guardian.*email/.test(n)) return prefill.guardian_email || '';
    if (/emergency contact name/.test(n))  return prefill.emergency_name || '';
    if (/emergency contact phone/.test(n)) return prefill.emergency_phone || '';
    return '';
  }

  // ── Form template helpers ─────────────────────────────────────────────────────
  function getFormTemplate(key) {
    return _formTemplates?.[key] || null;
