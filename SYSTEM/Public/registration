    const body = btn.closest('.rpf-section-body');
    if (!body) return;
    const existing = body.querySelectorAll('[data-rpf-pickup-person]').length;
    const num = existing + 3;
    const group = document.createElement('div');
    group.setAttribute('data-rpf-solo', '1');
    group.setAttribute('data-rpf-pickup-person', '1');
    group.innerHTML = `<div class="rpf-pickup-person-heading">Person ${num}</div>
