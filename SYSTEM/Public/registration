  const DEFAULT_COC_SECTIONS = [
    { id: 'intro',     title: 'Introduction',                  visible: true, content: `<p>We are committed to creating a safe, respectful, and welcoming environment for everyone involved in this production.</p><p>By participating, all cast members agree to contribute positively to the rehearsal and performance process.</p>` },
    { id: 'respect',   title: 'Respect &amp; Inclusion',       visible: true, content: `<p>All participants are expected to treat others with kindness, respect, and professionalism.</p><p>Bullying, harassment, discrimination, or inappropriate behaviour will not be tolerated.</p>` },
