  window.rpfToggleMinorFields = function(checkbox) {
    const body = checkbox.closest('.rpf-section-body, .rpf-panel');
    if (!body) return;
    body.querySelectorAll('[data-rpf-minor]').forEach(el => { el.style.display = checkbox.checked ? '' : 'none'; });
