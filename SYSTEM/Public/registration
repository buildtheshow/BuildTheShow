  // ── Token substitution ───────────────────────────────────────────────────────
  function buildTokenMap() {
    const perfName = _prefill ? [_prefill.preferred_name || _prefill.first_name, _prefill.last_name].filter(Boolean).join(' ') : '';
    return {
      '{{organisation_name}}': _org?.name || _org?.abbreviation || '',
      '{{org_name}}':          _org?.name || _org?.abbreviation || '',
      '{{show_name}}':         _prod?.title || '',
      '{{show_venue}}':        _prod?.venue || '',
      '{{rehearsal_start_date}}': _prod?.start_date ? new Date(_prod.start_date + 'T00:00:00').toLocaleDateString('en-CA', { month: 'long', day: 'numeric', year: 'numeric' }) : '',
      '{{rehearsal_end_date}}':   _prod?.end_date   ? new Date(_prod.end_date   + 'T00:00:00').toLocaleDateString('en-CA', { month: 'long', day: 'numeric', year: 'numeric' }) : '',
      '{{performer_name}}':  perfName,
      '{{child_name}}':      perfName,
      '{{etransfer_email}}': _regSettings?.payment_settings?.etransfer_email || '',
      '{{org_email}}':       _regSettings?.payment_settings?.etransfer_email || '',
    };
  }

  function subTokens(html) {
    if (!html) return html || '';
    const map = buildTokenMap();
    return html
      .replace(/\{\{[^}]+\}\}/g, t => map[t] ?? t)
      .replace(/<p>\s*<br\s*\/?>\s*<\/p>/gi, '')
      .replace(/<p>\s*&nbsp;\s*<\/p>/gi, '');
  }

  // ── Age helpers ──────────────────────────────────────────────────────────────
  function rpfParseDateValue(value) {
    if (!value) return null;
    if (value instanceof Date) return value;
    const m = String(value).match(/^(\d{4})-(\d{2})-(\d{2})$/);
    if (m) return new Date(Number(m[1]), Number(m[2]) - 1, Number(m[3]));
    return new Date(value);
  }

  function rpfCalcAge(dob) {
    const d = rpfParseDateValue(dob);
    if (!d || isNaN(d)) return null;
    const today = new Date();
    let age = today.getFullYear() - d.getFullYear();
    const m = today.getMonth() - d.getMonth();
    if (m < 0 || (m === 0 && today.getDate() < d.getDate())) age--;
    return age >= 0 ? age : null;
  }

  function rpfTodayInputValue() {
    const d = new Date();
    return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
  }

  // ── DOM helpers ──────────────────────────────────────────────────────────────
  window.rpfCheckGuardianFields = function(dobInput) {
    const note = dobInput.closest('.rpf-form-group')?.querySelector('[data-rpf-age-note]');
    if (note) {
      const age = rpfCalcAge(dobInput.value);
      note.textContent = age === null ? '' : `Age today: ${age} ${age === 1 ? 'year old' : 'years old'}`;
      note.style.display = age === null ? 'none' : '';
    }
    const panel = dobInput.closest('.rpf-panel');
    if (!panel) return;
    const age = rpfCalcAge(dobInput.value);
    const isUnder19 = age !== null && age < 19;
    panel.querySelectorAll('[data-rpf-guard]').forEach(el => { el.style.display = isUnder19 ? '' : 'none'; });
    const soloCheckbox = panel.querySelector('.rpf-solo-toggle-row input:not([data-rpf-minor-toggle])');
    if (soloCheckbox && age !== null) {
      const shouldBeChecked = age >= 19;
      if (soloCheckbox.checked !== shouldBeChecked) {
        soloCheckbox.checked = shouldBeChecked;
        rpfToggleSoloPickup(soloCheckbox);
      }
    }
    panel.querySelectorAll('[data-rpf-minor-toggle]').forEach(cb => {
      if (age !== null) cb.checked = age < 19;
      rpfToggleMinorFields(cb);
    });
  };

  window.rpfToggleSoloPickup = function(checkbox) {
    const body = checkbox.closest('.rpf-section-body, .rpf-panel');
    if (!body) return;
    body.querySelectorAll('[data-rpf-solo]').forEach(el => { el.style.display = checkbox.checked ? 'none' : ''; });
