  function isTemplateEnabled(def) {
    const saved = _regSettings || {};
    const groupKey = `form_group_${String(def.group || '').toLowerCase().replace(/[^a-z0-9]+/g, '_')}`;
    const groupOn = saved[groupKey] !== false;
    if (!groupOn) return false;
    const defKey = `form_${def.key}`;
    if (saved[defKey] !== undefined) return saved[defKey] !== false;
    return def.defaultOn;
  }

  function registrationFormVisibleFields(fields = []) {
    const visible = [];
    let skipping = false;
    fields.forEach(field => {
      const raw = String(field || '').trim();
      if (!raw) return;
      if (raw.startsWith('{section}')) {
        const title = raw.slice(9).trim();
        skipping = /^signature$/i.test(title) || /final acknowledgement|final acknowledgment/i.test(title);
        if (!skipping) visible.push(field);
        return;
      }
      if (skipping) return;
      const label = raw.replace(/^\{(?:minor|solo|guard)\}/, '').replace(/\s*\*$/, '').trim();
      if (!/\bsignature\b/i.test(label)) visible.push(field);
    });
    return visible;
  }

