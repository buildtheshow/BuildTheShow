      <div class="rpf-form-group rpf-pickup-field rpf-pickup-field--last"><label class="rpf-label">Phone number</label><input type="tel" class="rpf-input" data-field-name="Authorised pickup ${num} phone number" /></div>`;
    btn.closest('.rpf-form-group')?.before(group);
    const soloCheckbox = body.querySelector('.rpf-solo-toggle-row input');
