<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Registration | Build The Show</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Alex+Brush&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/ASSETS/styles/casting-card.css?v=in-show-card-20260527" />
  <style>
    /* ── Design tokens ── */
    :root {
      --purple:      #572e88;
      --purple-dark: #1a1530;
      --gold:        #efab45;
      --green:       #769e7b;
      --red:         #d1523d;
      --blue:        #476aaa;
      --ink:         #1a1530;
      --muted:       #6a5a80;
      --soft:        #9a90b0;
      --line:        rgba(87,46,136,0.12);
      --bg:          #efefef;
      --font:        'Segoe UI', system-ui, -apple-system, sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }

    /* ── Loading / error states ── */
    body {
      min-height: 100vh;
      background: var(--bg);
      color: var(--ink);
      font-family: var(--font);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }
    body.form-ready { display: block; }
    .loading-shell {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      padding: 2rem;
      text-align: center;
    }
    .loading-logo {
      width: 48px; height: 48px; border-radius: 50%;
      background: var(--purple);
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-size: 1.4rem; font-weight: 900;
    }
    .loading-title { font-size: 1rem; font-weight: 700; color: var(--purple); }
    .loading-copy  { font-size: 0.82rem; color: var(--muted); max-width: 280px; line-height: 1.5; }
    .loading-spinner {
      width: 24px; height: 24px;
      border: 2.5px solid rgba(87,46,136,0.15);
      border-top-color: var(--purple);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .error-shell {
      display: none; flex-direction: column; align-items: center;
      gap: 0.85rem; padding: 2rem; text-align: center; max-width: 360px;
    }
    .error-icon { font-size: 2rem; }
    .error-title { font-size: 1rem; font-weight: 700; color: var(--ink); }
    .error-copy  { font-size: 0.82rem; color: var(--muted); line-height: 1.5; }

    /* ── RPF shell ── */
    .rpf-shell {
      display: flex;
      height: 100vh;
      overflow: hidden;
      background: var(--bg);
      font-family: var(--font);
    }

    /* ── Left sidebar ── */
    .rpf-left-bar {
      width: 240px;
      flex-shrink: 0;
      background: var(--purple);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      position: relative;
    }
    .rpf-left-bar::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: url('/ASSETS/Images/Grid-Glow-Purple.png');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      opacity: 0.05;
      pointer-events: none;
    }
    .rpf-left-bar > * { position: relative; z-index: 1; }

    .rpf-left-logo {
      padding: 1.25rem 1.1rem 0;
      flex-shrink: 0;
      display: flex;
      justify-content: center;
    }
    .rpf-left-logo img {
      max-height: 112px;
      max-width: 200px;
      width: auto;
      display: block;
      filter: brightness(0) invert(1);
      opacity: 0.9;
    }
    .rpf-left-logo-name {
      font-size: 0.72rem; font-weight: 850;
      color: rgba(255,255,255,0.7); letter-spacing: 0.02em;
    }

    .rpf-left-cards {
      position: relative;
      height: 160px;
      flex-shrink: 0;
      margin: 1.1rem 0.85rem 0.75rem;
    }
    .rpf-card-poster {
      position: absolute; left: 4px; top: 8px;
      width: 100px; aspect-ratio: 8.5 / 11;
      border-radius: 8px; overflow: hidden;
      box-shadow: 0 6px 20px rgba(0,0,0,0.45);
      transform: rotate(-6deg);
      background: #1a1530;
    }
    .rpf-card-poster img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .rpf-card-poster-ph {
      width: 100%; height: 100%;
      display: flex; align-items: center; justify-content: center;
      background: rgba(255,255,255,0.1);
      font-size: 2.2rem;
    }
    .rpf-card-inshow {
      position: absolute;
      left: 92px;
      top: 18px;
      width: 108px;
      transform: rotate(1.5deg);
    }
    .rpf-card-inshow .casting-card {
      width: 100%;
      cursor: default;
      box-shadow: 0 7px 22px rgba(0,0,0,0.36);
    }
    .rpf-card-inshow .casting-card:hover {
      transform: none;
      box-shadow: 0 7px 22px rgba(0,0,0,0.36);
    }

    .rpf-left-info {
      padding: 0 1rem 0.85rem;
      border-bottom: 1px solid rgba(255,255,255,0.12);
    }
    .rpf-left-prod-name { font-size: 0.8rem; font-weight: 850; color: #fff; line-height: 1.2; }
    .rpf-left-deadline  { font-size: 0.62rem; font-weight: 700; color: rgba(255,255,255,0.6); margin-top: 0.2rem; }

    .rpf-left-nav {
      flex: 1;
      overflow-y: auto;
      padding: 0.75rem 0;
      scrollbar-width: none;
    }
    .rpf-left-nav::-webkit-scrollbar { display: none; }
    .rpf-left-nav-heading {
      font-size: 0.56rem; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.1em;
      color: rgba(255,255,255,0.45);
      padding: 0 1rem 0.4rem;
    }

    .rpf-left-item { display: block; transition: background 0.1s; }
    .rpf-left-item-main {
      display: flex; align-items: center; gap: 0.6rem;
      padding: 0.48rem 1rem; cursor: pointer;
    }
    .rpf-left-item:hover { background: rgba(255,255,255,0.08); }
    .rpf-left-item.rpf-active { background: rgba(255,255,255,0.14); }

    .rpf-left-dot {
      width: 20px; height: 20px; border-radius: 50%;
      border: 2px solid rgba(255,255,255,0.35);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.55rem; font-weight: 800;
      color: rgba(255,255,255,0.5);
      flex-shrink: 0; transition: all 0.15s;
    }
    .rpf-left-item.rpf-active .rpf-left-dot { border-color: #fff; background: #fff; color: var(--purple); }
    .rpf-left-item.rpf-done   .rpf-left-dot { border-color: #34d371; background: #34d371; color: #fff; }

    .rpf-left-label { font-size: 0.72rem; font-weight: 700; color: rgba(255,255,255,0.65); line-height: 1.2; }
    .rpf-left-item.rpf-active .rpf-left-label { color: #fff; }
    .rpf-left-item.rpf-done   .rpf-left-label { color: rgba(255,255,255,0.55); }

    .rpf-left-sublist {
      display: none; flex-direction: column; gap: 0.16rem;
      padding: 0.1rem 0.9rem 0.72rem 2.75rem;
    }
    .rpf-left-item.rpf-active .rpf-left-sublist { display: flex; }
    .rpf-left-subitem {
      display: flex; align-items: center; gap: 0.42rem;
      color: rgba(255,255,255,0.66); font-size: 0.6rem; font-weight: 750;
      line-height: 1.18; padding: 0.16rem 0;
    }
    .rpf-left-subdot {
      width: 0.72rem; height: 0.72rem; border-radius: 50%;
      border: 1.5px solid rgba(255,255,255,0.28);
      display: flex; align-items: center; justify-content: center;
      color: transparent; font-size: 0.48rem; font-weight: 950; flex: 0 0 auto;
    }
    .rpf-left-subitem.rpf-sub-done { color: rgba(255,255,255,0.86); }
    .rpf-left-subitem.rpf-sub-done .rpf-left-subdot { background: #34d371; border-color: #34d371; color: #fff; }

    /* ── Main content area ── */
    .rpf-main {
      flex: 1 1 0;
      min-width: 0;
      overflow-y: auto;
      background: var(--bg);
    }
    .rpf-page { max-width: 640px; margin: 0 auto; padding: 2rem 1.5rem 5rem; }
    .rpf-card { background: #fff; border-radius: 18px; overflow: hidden; }
    .rpf-body { padding: 2.15rem 1.75rem 0; }

    /* ── Steps / panels ── */
    .rpf-panel { display: none; }
    .rpf-panel.rpf-active { display: block; }
    .rpf-step-title {
      color: var(--ink);
      font-size: 1.52rem; font-weight: 950; line-height: 1.08;
      text-align: center; margin: 0 auto 1.1rem; max-width: 90%;
    }
    .rpf-prefill-badge {
      display: block;
      background: #f1fbf5; border-left: 4px solid #34d371;
      padding: 0.5rem 0.7rem;
      font-size: 0.75rem; font-weight: 800; color: #1a7540;
      margin: 0 auto 0.9rem; text-align: left;
    }

    /* ── Sections within a panel ── */
    .rpf-section {
      margin: 0 0 1.25rem;
      border-radius: 14px; overflow: hidden;
      box-shadow: 0 2px 12px rgba(0,0,0,0.10), 0 1px 3px rgba(0,0,0,0.07);
    }
    .rpf-section-head {
      display: flex; align-items: center; justify-content: space-between;
      background: var(--rpf-head, var(--purple));
      color: var(--rpf-ink, #ffffff);
      padding: 0.55rem 1rem;
      font-size: 0.78rem; font-weight: 900;
      text-transform: uppercase; letter-spacing: 0.08em;
    }
    .rpf-section-body { padding: 1rem; background: var(--rpf-bg, #ffffff); }

    /* ── Fields ── */
    .rpf-form-section-divider {
      margin: 1.55rem 0 0.7rem; padding-bottom: 0.45rem;
      border-bottom: 1.5px solid rgba(87,46,136,0.12);
      font-size: 1.02rem; font-weight: 950;
      letter-spacing: 0; color: var(--ink); text-align: center;
    }
    .rpf-form-section-divider:first-child { margin-top: 0; }
    .rpf-section-text { font-size: 0.84rem; color: #333; line-height: 1.65; margin: 0.15rem 0 0.75rem; }
    .rpf-section-text p { margin: 0 0 0.45em; }
    .rpf-section-text p:last-child { margin-bottom: 0; }
    .rpf-form-group { margin-bottom: 0.75rem; }
    .rpf-form-group:last-child { margin-bottom: 0; }
    .rpf-label { display: block; font-size: 0.78rem; font-weight: 700; color: #000; margin-bottom: 0.35rem; letter-spacing: 0.01em; }
    .rpf-req { color: var(--red); }
    .rpf-input {
      width: 100%; padding: 0.52rem 0.75rem;
      border: 1.5px solid #ebe6f1; border-radius: 8px;
      font-size: 0.875rem; font-family: var(--font);
      color: #000; background: #fff;
      outline: none; box-sizing: border-box; transition: border-color 0.15s;
    }
    .rpf-input:focus { border-color: var(--purple); }
    .rpf-input.rpf-prefilled { background: #eef9f2; border-color: var(--green); color: #1a2e1d; }
    .rpf-form-group:has(.rpf-input.rpf-prefilled) .rpf-label::after { content: " \2713"; color: var(--green); font-weight: 900; margin-left: 0.3em; }
    .rpf-input:not(.rpf-prefilled):not(:focus) { border-color: #ddd8e8; }
    textarea.rpf-input { resize: vertical; min-height: 80px; }
    .rpf-age-note { margin-top: 0.38rem; font-size: 0.72rem; font-weight: 800; color: var(--purple); }

    /* ── Agree row / checkboxes ── */
    .rpf-agree-row {
      display: flex; align-items: flex-start; gap: 0.55rem;
      font-size: 0.8rem; color: #000; line-height: 1.45;
      cursor: pointer; margin-top: 0.4rem;
    }
    .rpf-agree-row input { flex-shrink: 0; margin-top: 0.15rem; accent-color: var(--purple); cursor: pointer; }

    /* ── Medical reveal ── */
    .rpf-medical-reveal {
      border: 1px solid rgba(71,106,170,0.14); border-radius: 10px;
      background: #fff; padding: 0.72rem 0.85rem;
    }
    .rpf-medical-toggle {
      display: flex; align-items: flex-start; gap: 0.58rem;
      cursor: pointer; margin: 0;
      font-size: 0.82rem; font-weight: 850; color: var(--ink); line-height: 1.35;
    }
    .rpf-medical-toggle input { flex: 0 0 auto; margin-top: 0.12rem; width: 1rem; height: 1rem; accent-color: var(--blue); cursor: pointer; }
    .rpf-medical-details { display: none; margin-top: 0.65rem; }
    .rpf-medical-reveal:has(.rpf-medical-toggle input:checked) .rpf-medical-details { display: block; }
    .rpf-medical-details .rpf-label { color: #364c7d; }

    /* ── Solo / pickup toggles ── */
    .rpf-solo-toggle-row {
      display: flex; align-items: center; gap: 0.65rem;
      padding: 0.7rem 0.9rem; background: rgba(87,46,136,0.06);
      border-radius: 10px; cursor: pointer; margin-bottom: 0.9rem;
    }
    .rpf-solo-toggle-row input { width: 1rem; height: 1rem; accent-color: var(--purple); cursor: pointer; flex-shrink: 0; margin: 0; }
    .rpf-solo-toggle-label { font-size: 0.82rem; font-weight: 800; color: #000; }
    .rpf-pickup-person-heading {
      display: flex; align-items: center; justify-content: space-between;
      margin: 1rem 0 0; padding: 0.52rem 0.8rem;
      border: 1px solid rgba(87,46,136,0.14); border-bottom: 0;
      border-radius: 12px 12px 0 0;
      background: var(--blue); color: #fff;
      font-size: 0.7rem; font-weight: 950; letter-spacing: 0.08em; text-transform: uppercase;
    }
    .rpf-pickup-person-heading:first-child { margin-top: 0; }
    .rpf-pickup-field {
      margin-bottom: 0; padding: 0.72rem 0.8rem;
      border: 1px solid rgba(87,46,136,0.14); border-top: 0; background: #fff;
    }
    .rpf-pickup-field--last { margin-bottom: 1rem; border-radius: 0 0 12px 12px; box-shadow: 0 8px 22px rgba(26,21,48,0.08); }
    .rpf-pickup-field .rpf-label { color: #4a3d6b; font-size: 0.72rem; }
    .rpf-pickup-add-btn {
      display: flex; align-items: center; justify-content: center; gap: 0.45rem;
      width: 100%; background: none;
      border: 1.5px dashed rgba(87,46,136,0.3); border-radius: 8px;
      padding: 0.52rem 0.9rem; font-size: 0.78rem; font-weight: 800;
      color: var(--purple); cursor: pointer; font-family: var(--font); margin-bottom: 0.75rem;
      transition: background 0.1s;
    }
    .rpf-pickup-add-btn:hover { background: rgba(87,46,136,0.06); }

    /* ── Sig preview ── */
    .rpf-sig-preview {
      font-family: 'Alex Brush', cursive;
      font-size: 2rem; color: var(--ink);
      line-height: 1.1; min-height: 2.5rem;
      margin-top: 0.35rem; padding: 0.2rem 0;
      border-bottom: 1.5px solid rgba(87,46,136,0.18);
    }

    /* ── CoC / agreements ── */
    .rpf-coc, .rpf-media-release { display: flex; flex-direction: column; gap: 0.9rem; }
    .rpf-coc-section { background: #fff; border-radius: 10px; border: 1px solid rgba(87,46,136,0.1); padding: 0.85rem 1rem; }
    .rpf-coc-section-title { font-size: 0.82rem; font-weight: 900; color: var(--ink); margin-bottom: 0.5rem; }
    .rpf-coc-section-body { font-size: 0.83rem; color: #333; line-height: 1.65; }
    .rpf-coc-section-body p { margin: 0 0 0.45em; }
    .rpf-coc-section-body p:last-child { margin-bottom: 0; }
    .rpf-coc-section-body ul { padding-left: 1.4em; margin: 0.35em 0 0.45em; }
    .rpf-coc-section-body li { margin-bottom: 0.2em; }
    .rpf-mr-section-label { font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.07em; color: var(--muted); margin-bottom: 0.4rem; }
    .rpf-mr-text { font-size: 0.83rem; color: #333; line-height: 1.65; }
    .rpf-mr-text p { margin: 0 0 0.45em; }
    .rpf-mr-text p:last-child { margin-bottom: 0; }
    .rpf-mr-text ul { padding-left: 1.4em; margin: 0.35em 0 0.45em; }
    .rpf-mr-text li { margin-bottom: 0.2em; }
    .rpf-mr-sig-block {
      margin-top: 1rem;
      background: rgba(255,255,255,0.72);
      border: 1.5px solid rgba(87,46,136,0.12);
      border-radius: 14px;
      padding: 1rem;
    }
    .rpf-mr-sig-row { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: 0.85rem 1rem; }
    .rpf-mr-sig-row + .rpf-mr-sig-row { margin-top: 0.9rem; }
    .rpf-mr-sig-field { min-width: 0; }
    .rpf-mr-sig-field label { display: block; font-size: 0.75rem; font-weight: 850; color: var(--ink); margin-bottom: 0.4rem; }
    .rpf-mr-sig-field input {
      width: 100%;
      border: 1.5px solid rgba(87,46,136,0.18);
      border-radius: 9px;
      padding: 0.62rem 0.78rem;
      background: #fff;
      color: var(--ink);
      font: 600 0.88rem var(--font);
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .rpf-mr-sig-field input:focus {
      border-color: var(--purple);
      box-shadow: 0 0 0 3px rgba(87,46,136,0.12);
    }
    .rpf-mr-guardian-block { margin-top: 1.2rem; padding-top: 1.15rem; border-top: 1.5px dashed rgba(87,46,136,0.18); }
    .rpf-mr-guardian-label { font-size: 0.74rem; font-weight: 950; color: var(--purple); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem; }
    .rpf-mr-perm-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; padding: 0.75rem 0; border-bottom: 1px solid rgba(87,46,136,0.1); }
    .rpf-mr-perm-row:last-child { border-bottom: none; padding-bottom: 0; }
    .rpf-mr-perm-label { font-size: 0.83rem; color: #333; line-height: 1.45; flex: 1 1 0; }
    .rpf-mr-perm-choices { display: flex; gap: 0.35rem; flex-shrink: 0; }
    .rpf-mr-perm-choice { display: flex; align-items: center; gap: 0.3rem; font-size: 0.78rem; font-weight: 800; cursor: pointer; padding: 0.35rem 0.6rem; border-radius: 7px; border: 1.5px solid rgba(209,82,61,0.22); white-space: nowrap; transition: all 0.12s; }
    .rpf-mr-perm-choice input[type="radio"] { display: none; }
    .rpf-mr-perm-agree { color: var(--red); }
    .rpf-mr-perm-disagree { color: #888; }
    .rpf-mr-perm-choice:has(input:checked).rpf-mr-perm-agree { background: var(--red); color: #fff; border-color: var(--red); }
    .rpf-mr-perm-choice:has(input:checked).rpf-mr-perm-disagree { background: #888; color: #fff; border-color: #888; }
    .rpf-mr-perms { display: flex; flex-direction: column; gap: 0; }

    /* ── Upload placeholder ── */
    .rpf-upload {
      display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
      padding: 1.5rem 1rem;
      border: 2px dashed rgba(87,46,136,0.25); border-radius: 10px;
      text-align: center; cursor: pointer;
      transition: border-color 0.15s;
    }
    .rpf-upload:hover { border-color: var(--purple); }
    .rpf-upload-hint { font-size: 0.82rem; color: var(--muted); font-weight: 600; }
    .rpf-upload-sub  { font-size: 0.72rem; color: var(--soft); }

    /* ── Final agreement ── */
    .rpf-final-agree { padding: 0.35rem 0; }
    .rpf-final-kicker { font-size: 0.62rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); text-align: center; margin-bottom: 0.4rem; }
    .rpf-final-title  { font-size: 2.2rem; font-weight: 950; text-align: center; color: var(--ink); letter-spacing: -0.01em; }
    .rpf-final-copy   { font-size: 0.88rem; color: var(--muted); text-align: center; line-height: 1.55; margin: 0.7rem auto 1.25rem; max-width: 470px; }
    .rpf-final-agree-box {
      background: rgba(87,46,136,0.06);
      border: 1.5px solid rgba(87,46,136,0.08);
      border-radius: 13px;
      padding: 1rem 1.1rem;
      margin-bottom: 1.1rem;
    }
    .rpf-final-agree-box .rpf-agree-row { margin: 0; font-size: 0.88rem; line-height: 1.45; }

    /* ── Production fee ── */
    .rpf-pf { display: flex; flex-direction: column; gap: 0.5rem; }
    .rpf-pf-block { display: flex; flex-direction: column; gap: 0.4rem; }
    .rpf-pf-block-title { font-size: 0.8rem; font-weight: 900; color: var(--ink); margin-bottom: 0.15rem; }
    .rpf-pf-row { display: flex; justify-content: space-between; align-items: baseline; padding: 0.35rem 0; border-bottom: 1px solid rgba(87,46,136,0.07); font-size: 0.83rem; }
    .rpf-pf-row-label { color: var(--muted); }
    .rpf-pf-row-value { font-weight: 700; color: var(--ink); }
    .rpf-pf-none { font-size: 0.83rem; color: rgba(87,46,136,0.4); font-style: italic; padding: 0.5rem 0; }
    .rpf-pf-divider { border: none; border-top: 1.5px solid rgba(87,46,136,0.1); margin: 0.25rem 0; }
    .rpf-pf-text { font-size: 0.83rem; color: #333; line-height: 1.65; }
    .rpf-pf-text p { margin: 0 0 0.45em; }
    .rpf-pf-text p:last-child { margin-bottom: 0; }
    .rpf-pf-text p:empty { display: none; }
    .rpf-pf-text div:has(>br:only-child) { display: none; }
    .rpf-pf-text ul { margin: 0 0 0.45em; padding-left: 1.4em; }
    .rpf-pf-text li { margin-bottom: 0.15em; }
